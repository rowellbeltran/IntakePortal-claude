# UiPath Coded Web App — Environment Variables
# Copy this file to .env and fill in your values.
# Run "uip login" then "uip codedapp pack dist" to get a client ID if you don't have one.

# ─── UiPath Cloud Coordinates ─────────────────────────────────────────────────
VITE_UIPATH_BASE_URL=https://staging.uipath.com
VITE_UIPATH_ORG_NAME=uspsenablement
VITE_UIPATH_TENANT_NAME=AIFabricEnabled

# ─── OAuth External Application ───────────────────────────────────────────────
# Create a Non-Confidential External App in UiPath Automation Cloud:
#   Automation Cloud → Admin → External Applications → Add Application
#   Redirect URI: http://localhost:5173
VITE_UIPATH_CLIENT_ID=

# ─── OAuth Scopes ─────────────────────────────────────────────────────────────
# Space-separated list. See .github/skills/uipath-coded-apps/references/oauth-scopes.md
# Minimum scopes for ROI task creation / retrieval:
VITE_UIPATH_SCOPE=OR.Tasks OR.Tasks.Write

# ─── Action Center Folder ─────────────────────────────────────────────────────
# Numeric folder ID where ROI approval tasks will be created.
# Find it in Orchestrator → Folders → <your folder> → URL contains folderId=<n>
VITE_UIPATH_FOLDER_ID=
